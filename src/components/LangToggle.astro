---
// Swaps locale while preserving the logical route (see src/data/routes.ts).
import { pairFor, withBase } from '../data/routes';

interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;

const pair = pairFor(Astro.url.pathname);
let target = lang === 'it' ? '/en' : '/';
if (pair) target = lang === 'it' ? pair.en : pair.it;
target = withBase(target);

const label = lang === 'it' ? 'EN' : 'IT';
---

<a class="lang-toggle" href={target} aria-label={`Switch language to ${label}`}>{label}</a>

<style>
  /* Fixed, unobtrusive pill in the top-right corner */
  .lang-toggle {
    position: fixed;
    top: var(--space-s);
    right: var(--space-s);
    z-index: 50;
    font-family: var(--font-display);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 0.35em 0.6em;
    border: 1.5px solid currentColor;
    border-radius: 999px;
    background: var(--bg);
    mix-blend-mode: multiply;
  }
</style>
