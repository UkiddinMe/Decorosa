---
// Swaps locale while preserving the logical route (see src/data/routes.ts).
import { pairFor } from '../data/routes';

interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;

const pair = pairFor(Astro.url.pathname);
let target = lang === 'it' ? '/en' : '/';
if (pair) target = lang === 'it' ? pair.en : pair.it;

const label = lang === 'it' ? 'EN' : 'IT';
---

<a class="lang-toggle" href={target} aria-label={`Switch language to ${label}`}>{label}</a>
