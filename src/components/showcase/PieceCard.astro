---
import type { Piece } from '../../data/pieces';

interface Props {
  piece: Piece;
  lang: 'it' | 'en';
}
const { piece, lang } = Astro.props;
const txt = piece.i18n[lang];
const { angleDeg, radius, dropY } = piece.spiral;
// Placement of this card within the spiral (rotated/offset inside the spinning group).
const style = `--angle:${angleDeg}deg;--radius:${radius}px;--drop:${dropY}px`;
---

<article
  class="card"
  style={style}
  data-piece={piece.id}
  data-world={piece.world}
  data-angle={angleDeg}
>
  <button class="card__hit" data-open={piece.id} aria-label={txt.title}></button>
  <!-- Placeholder media (colored per world) until client artwork lands -->
  <div class="card__media"></div>
  <h2 class="card__title">{txt.title}</h2>
  {txt.subtitle && <p class="card__subtitle">{txt.subtitle}</p>}
</article>

<style>
  .card {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--card-w);
    height: var(--card-h);
    margin-left: calc(var(--card-w) / -2);
    margin-top: calc(var(--card-h) / -2);
    /* Place on the spiral, then counter-rotate by (spin + angle) so the card always
       faces the viewer (billboard) — keeps artwork readable as the spiral turns. */
    transform: rotateY(var(--angle)) translateZ(var(--radius)) translateY(var(--drop))
      rotateY(calc((var(--spin, 0deg) + var(--angle)) * -1));
    transform-style: preserve-3d;
    display: grid;
    grid-template-rows: 1fr auto auto;
    gap: 0.4rem;
    color: var(--c-black);
  }
  .card__hit {
    position: absolute;
    inset: 0;
    z-index: 2;
    /* the .scene layers are pointer-events: none; clicks land here */
    pointer-events: auto;
    appearance: none;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
  }
  .card__media {
    border-radius: 0.5rem;
    box-shadow: 0 12px 30px rgb(0 0 0 / 0.18);
    background: var(--c-grey);
  }
  .card[data-world='disco'] .card__media {
    background: linear-gradient(150deg, #16203f, #2b3b6b 60%, #8aa0d8);
  }
  .card[data-world='jungle'] .card__media {
    background: linear-gradient(150deg, #1f5132, #3f8f53 60%, #8fc79a);
  }
  .card[data-world='desert'] .card__media {
    background: linear-gradient(150deg, #e9b15a, #f4d08a 55%, #f7e7c5);
  }
  .card__title {
    font-size: var(--step-0);
    text-align: center;
  }
  .card__subtitle {
    margin: 0;
    text-align: center;
    font-size: var(--step--1);
    color: var(--c-grey);
  }
</style>
