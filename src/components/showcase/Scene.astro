---
import PieceCard from './PieceCard.astro';
import Ladder3D from './Ladder3D.astro';
import DetailPanel from './DetailPanel.astro';
import { pieces, type Piece } from '../../data/pieces';

interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;

// Scroll length = one viewport per piece (+1 lead-in); descent spans the lowest card.
const travel = Math.max(0, ...pieces.map((p) => p.spiral.dropY));
const driverVh = (pieces.length + 1) * 130;

// Server-side layer assignment at spin = 0 (front of orbit = positive z);
// showcase.ts re-sorts cards between the layers as the spiral turns.
const isFront = (p: Piece) => Math.cos((p.spiral.angleDeg * Math.PI) / 180) >= 0;
---

<!-- 3D experience: a sticky scene inside a tall scroll driver -->
<section class="viewport" data-driver data-travel={travel} style={`height:${driverVh}svh`}>
  <!-- clip on a plain 2D sticky wrapper; perspective on a separate inner element so
       WebKit/Safari doesn't flatten the 3D (overflow + perspective on one node is buggy) -->
  <div class="scene-clip" data-scene>
    <div class="sky" data-sky aria-hidden="true"></div>
    <!-- Occlusion sandwich: cards behind the ladder / the ladder / cards in front.
         Each .scene is its own 3D context (own perspective), so card and ladder planes
         can never slice through each other; showcase.ts moves each card between the two
         card layers as it orbits, so cards still read as going *around* the ladder. -->
    <div class="scene">
      <div class="stage">
        <div class="spiral" data-spiral>
          {pieces.filter((p) => !isFront(p)).map((p) => <PieceCard piece={p} lang={lang} />)}
        </div>
      </div>
    </div>
    <div class="scene" aria-hidden="true">
      <div class="stage">
        <div class="ladder-group" data-ladder><Ladder3D /></div>
      </div>
    </div>
    <div class="scene">
      <div class="stage">
        <div class="spiral" data-spiral>
          {pieces.filter(isFront).map((p) => <PieceCard piece={p} lang={lang} />)}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pre-paint: when arriving via the entry transition, park the spirals one scroll slot
     back (same start pose as playIntro in showcase.ts) BEFORE first paint, so the first
     card never flashes at its resting spot. Runs inline (and re-runs on SPA swaps) since
     astro:page-load fires only after the page is already visible. -->
<script is:inline data-astro-rerun>
  if (sessionStorage.getItem('decorosa:enter-intro')) {
    document.querySelectorAll('[data-spiral]').forEach(function (el) {
      el.style.setProperty('--spin', '-240deg');
      el.style.setProperty('--rise', '700px');
    });
  }
</script>

<!-- Bespoke world detail panels (opened by clicking a card) -->
{pieces.map((p) => <DetailPanel piece={p} lang={lang} />)}

<!-- Reduced-motion / no-3D fallback: a plain vertical list -->
<ul class="fallback">
  {
    pieces.map((p) => {
      const t = p.i18n[lang];
      return (
        <li class="fallback__item" data-world={p.world}>
          <div class="fallback__media" />
          <div>
            <h2>{t.title}</h2>
            {t.subtitle && <p class="fallback__subtitle">{t.subtitle}</p>}
            <p>{t.body}</p>
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  .viewport {
    position: relative;
  }
  .scene-clip {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
  }
  /* Full-bleed sky (cropped from the brand image) that gently drifts with the scroll. */
  .sky {
    position: absolute;
    left: 0;
    right: 0;
    top: -12%;
    height: 124%;
    background: var(--sky-bg);
    transform: translateY(var(--sky-shift, 0px));
    will-change: transform;
    z-index: 0;
  }
  .scene {
    position: absolute;
    inset: 0;
    perspective: var(--scene-perspective);
    z-index: 1;
    /* stacked layers must not block clicks on cards in the layers beneath */
    pointer-events: none;
  }
  .stage {
    position: absolute;
    top: 50%;
    left: var(--stage-left);
    transform-style: preserve-3d;
    /* scale lets us keep one set of spiral coords across breakpoints
       (--scene-scale shrinks on mobile — see tokens.css) */
    transform: scale(var(--scene-scale)) rotateX(var(--stage-tilt)) translateY(var(--descend, 0px));
  }
  .spiral,
  .ladder-group {
    position: absolute;
    top: 0;
    left: 0;
    transform-style: preserve-3d;
  }
  /* --rise lets the entrance intro offset the cards (not the ladder) one scroll slot down */
  .spiral {
    transform: translateY(var(--rise, 0px)) rotateY(var(--spin, 0deg));
  }
  /* Opposite spin + fixed diagonal incline, centered on the spiral axis (the card
     layers handle stacking, so no push-back is needed). */
  .ladder-group {
    transform: rotateY(var(--spin, 0deg)) rotateZ(var(--ladder-incline));
  }

  /* Fallback list (hidden unless reduced motion is requested) */
  .fallback {
    display: none;
  }
  .fallback__item {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    gap: var(--space-m);
    align-items: center;
    max-width: var(--maxw);
    margin: 0 auto var(--space-l);
    padding-inline: var(--space-m);
  }
  .fallback__media {
    aspect-ratio: 4 / 5;
    border-radius: 0.5rem;
    background: var(--c-grey);
  }
  .fallback__item[data-world='disco'] .fallback__media {
    background: var(--world-disco-bg);
  }
  .fallback__item[data-world='jungle'] .fallback__media {
    background: var(--world-jungle-bg);
  }
  .fallback__item[data-world='desert'] .fallback__media {
    background: var(--world-desert-bg);
  }
  .fallback__subtitle {
    color: var(--c-grey);
    font-family: var(--font-display);
  }

  @media (prefers-reduced-motion: reduce) {
    .viewport {
      display: none;
    }
    .fallback {
      display: block;
      padding-block: var(--space-l);
    }
  }
</style>
