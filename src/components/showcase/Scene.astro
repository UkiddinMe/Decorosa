---
import PieceCard from './PieceCard.astro';
import Ladder3D from './Ladder3D.astro';
import { pieces } from '../../data/pieces';

interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;

// Scroll length = one viewport per piece (+1 lead-in); descent spans the lowest card.
const travel = Math.max(0, ...pieces.map((p) => p.spiral.dropY));
const driverVh = (pieces.length + 1) * 100;
---

<!-- 3D experience: a sticky scene inside a tall scroll driver -->
<section class="viewport" data-driver data-travel={travel} style={`height:${driverVh}svh`}>
  <div class="scene" data-scene>
    <div class="stage" data-stage>
      <div class="ladder-group" data-ladder><Ladder3D /></div>
      <div class="spiral" data-spiral>
        {pieces.map((p) => <PieceCard piece={p} lang={lang} />)}
      </div>
    </div>
  </div>
</section>

<!-- Reduced-motion / no-3D fallback: a plain vertical list -->
<ul class="fallback">
  {
    pieces.map((p) => {
      const t = p.i18n[lang];
      return (
        <li class="fallback__item" data-world={p.world}>
          <div class="fallback__media" />
          <div>
            <h2>{t.title}</h2>
            {t.subtitle && <p class="fallback__subtitle">{t.subtitle}</p>}
            <p>{t.body}</p>
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  .viewport {
    position: relative;
  }
  .scene {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    perspective: var(--scene-perspective);
  }
  .stage {
    position: absolute;
    top: 50%;
    left: 50%;
    transform-style: preserve-3d;
    /* scale lets us keep one set of spiral coords across breakpoints */
    transform: scale(var(--scene-scale, 1)) rotateX(8deg) translateY(var(--descend, 0px));
  }
  .spiral,
  .ladder-group {
    position: absolute;
    top: 0;
    left: 0;
    transform-style: preserve-3d;
  }
  .spiral {
    transform: rotateY(var(--spin, 0deg));
  }
  /* opposite spin + fixed diagonal incline */
  .ladder-group {
    transform: rotateY(var(--spin, 0deg)) rotateZ(13deg);
  }

  /* Mobile parity: shrink the whole projection rather than re-laying out */
  @media (max-width: 640px) {
    .stage {
      --scene-scale: 0.62;
    }
  }

  /* Fallback list (hidden unless reduced motion is requested) */
  .fallback {
    display: none;
  }
  .fallback__item {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    gap: var(--space-m);
    align-items: center;
    max-width: var(--maxw);
    margin: 0 auto var(--space-l);
    padding-inline: var(--space-m);
  }
  .fallback__media {
    aspect-ratio: 4 / 5;
    border-radius: 0.5rem;
    background: var(--c-grey);
  }
  .fallback__item[data-world='disco'] .fallback__media {
    background: linear-gradient(150deg, #16203f, #2b3b6b 60%, #8aa0d8);
  }
  .fallback__item[data-world='jungle'] .fallback__media {
    background: linear-gradient(150deg, #1f5132, #3f8f53 60%, #8fc79a);
  }
  .fallback__item[data-world='desert'] .fallback__media {
    background: linear-gradient(150deg, #e9b15a, #f4d08a 55%, #f7e7c5);
  }
  .fallback__subtitle {
    color: var(--c-grey);
    font-family: var(--font-display);
  }

  @media (prefers-reduced-motion: reduce) {
    .viewport {
      display: none;
    }
    .fallback {
      display: block;
      padding-block: var(--space-l);
    }
  }
</style>
