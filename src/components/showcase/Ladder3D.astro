---
// The central ladder running down the spiral's vertical axis — the *same* vector ladder
// shown on the landing, so it stays continuous across the entry transition. Its diagonal
// incline + opposite-direction spin are applied by the parent group (Scene.astro).
// The SVG lives inside a plain (flat) wrapper div: an <svg> placed directly in a
// preserve-3d context fails to rasterize in Chrome, but a flat div flattens it to a
// texture that composites correctly in 3D.
import Ladder from '../Ladder.astro';
---

<div class="ladder3d"><Ladder rungs={95} /></div>

<style>
  .ladder3d {
    position: absolute;
    top: 0;
    left: 0;
    width: 74px;
    height: 3601px; /* matches the SVG's 113:5499 aspect (rungs=95) — no distortion */
    transform: translate(-50%, -50%);
  }
  .ladder3d :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
