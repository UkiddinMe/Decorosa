---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Logo from '../../components/Logo.astro';
import Slogan from '../../components/Slogan.astro';
import LadderEntry from '../../components/LadderEntry.astro';
import { t } from '../../data/i18n';

const lang = 'en' as const;
const dict = t(lang);
---

<BaseLayout lang={lang}>
  <main class="landing">
    <h1 class="sr-only">DECOROSA</h1>
    <section class="landing__hero">
      <Logo contactsHref="/en/contact" contactsLabel={dict.nav.contacts} />
      <Slogan lead={dict.slogan.lead} items={dict.slogan.items} />
    </section>
    <LadderEntry showcaseHref="/en/showcase" enterLabel={dict.nav.enter} />
  </main>
</BaseLayout>

<style>
  .landing {
    min-height: 100svh;
    display: grid;
    grid-template-rows: 1fr auto;
    gap: var(--space-l);
    padding: var(--space-l) var(--space-m) var(--space-m);
  }
  .landing__hero {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: var(--space-l);
  }
</style>
