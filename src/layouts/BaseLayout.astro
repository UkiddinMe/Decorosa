---
import '../styles/tokens.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import LangToggle from '../components/LangToggle.astro';
import { t } from '../data/i18n';
import { pairFor } from '../data/routes';

interface Props {
  lang?: 'it' | 'en';
  title?: string;
  description?: string;
}

const { lang = 'it', title, description } = Astro.props;
const dict = t(lang);
const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;
const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = new URL('/assets/logo-original.png', base).href;

// hreflang alternates for this route (IT default + EN)
const pair = pairFor(Astro.url.pathname);
const alternates = pair
  ? [
      { hreflang: 'it', href: new URL(pair.it, base).href },
      { hreflang: 'en', href: new URL(pair.en, base).href },
      { hreflang: 'x-default', href: new URL(pair.it, base).href },
    ]
  : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <!-- First-paint gate (hard loads only — SPA swaps keep the old page visible anyway):
         hide the page until fonts, images and the shared sky texture are ready, then
         global.css fades everything in at once (html.is-loading → body opacity). -->
    <script is:inline>
      document.documentElement.classList.add('is-loading');
      (function () {
        var loaded = new Promise(function (r) {
          if (document.readyState === 'complete') r();
          else window.addEventListener('load', r, { once: true });
        });
        var fonts = document.fonts ? document.fonts.ready : Promise.resolve();
        var sky = new Promise(function (r) {
          var img = new Image();
          img.onload = img.onerror = r;
          img.src = '/assets/sky.jpg'; // keep in sync with --sky-bg (tokens.css)
        });
        var cap = new Promise(function (r) {
          setTimeout(r, 2500); // never hold the page hostage on a slow asset
        });
        Promise.race([Promise.all([loaded, fonts, sky]), cap]).then(function () {
          requestAnimationFrame(function () {
            document.documentElement.classList.remove('is-loading');
          });
        });
      })();
    </script>
  </head>
  <body>
    <slot />
    <LangToggle lang={lang} />
    <script>
      import '../scripts/transition.ts';
    </script>
  </body>
</html>
