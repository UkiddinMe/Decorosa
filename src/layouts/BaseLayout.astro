---
import '../styles/tokens.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import LangToggle from '../components/LangToggle.astro';
import { t } from '../data/i18n';
import { pairFor } from '../data/routes';

interface Props {
  lang?: 'it' | 'en';
  title?: string;
  description?: string;
}

const { lang = 'it', title, description } = Astro.props;
const dict = t(lang);
const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;
const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = new URL('/assets/logo-original.png', base).href;

// hreflang alternates for this route (IT default + EN)
const pair = pairFor(Astro.url.pathname);
const alternates = pair
  ? [
      { hreflang: 'it', href: new URL(pair.it, base).href },
      { hreflang: 'en', href: new URL(pair.en, base).href },
      { hreflang: 'x-default', href: new URL(pair.it, base).href },
    ]
  : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <slot />
    <LangToggle lang={lang} />
    <script>
      import '../scripts/transition.ts';
    </script>
  </body>
</html>
