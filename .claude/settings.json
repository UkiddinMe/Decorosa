{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Bash(cat .env*)",
      "Bash(* .env*)"
    ],
    "allow": [
      "PowerShell([console]::beep*)",
      "PowerShell([console]::beep(880,150); [console]::beep(1175,200))"
    ]
  }
}
